generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CateringRequest {
  id            String            @id @default(cuid())
  name          String
  phone         String
  email         String
  eventDate     String?
  guests        String?
  location      String?
  notes         String?
  internalNotes String?
  status        String            @default("NEW")
  isArchived    Boolean           @default(false)
  chatToken     String            @unique @default(cuid())
  chatEnabled   Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now()) @updatedAt
  selections    Json?
  messages      CateringMessage[]
}

model CateringMessage {
  id        String          @id @default(cuid())
  requestId String
  sender    ChatSender
  text      String
  createdAt DateTime        @default(now())
  request   CateringRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  imageUrl    String?
  category    String
  isVeg       Boolean  @default(false)
  isSpicy     Boolean  @default(false)
  isPopular   Boolean  @default(false)
  isAvailable Boolean  @default(true)
  inPos       Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isAvailable, sortOrder])
}

model MenuCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id              String   @id @default("global")
  phone           String   @default("")
  instagramUrl    String   @default("")
  truckToday      String   @default("")
  truckNext       String   @default("")
  updatedAt       DateTime @updatedAt
  nextDate        String   @default("")
  nextEnd         String   @default("")
  nextLocation    String   @default("")
  nextNotes       String   @default("")
  nextStart       String   @default("")
  todayEnd        String   @default("")
  todayLocation   String   @default("")
  todayNotes      String   @default("")
  todayStart      String   @default("")
  todayStatus     String   @default("CLOSED")
  bannerEnabled   Boolean  @default(false)
  bannerText      String?  @default("")
  businessName    String?  @default("Indian Food Truck")
  cityState       String?  @default("Hartford, CT")
  footerMessage   String?  @default("")
  publicEmail     String?  @default("")
  logoUrl         String?  @default("")
  cateringEnabled Boolean  @default(true)
  weeklySchedule  Json?
}

model SavedLocation {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  createdAt DateTime @default(now())
}

model CateringItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  priceKind   String
  amount      Float?
  minPeople   Int?
  unit        String?
  halfPrice   Float?
  fullPrice   Float?
  isVeg       Boolean  @default(false)
  isSpicy     Boolean  @default(false)
  isPopular   Boolean  @default(false)
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isAvailable, sortOrder])
}

model CateringCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  subtitle  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

enum ChatSender {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  customerName    String
  customerEmail   String
  customerPhone   String
  totalAmount     Int // In cents
  stripeSessionId String?     @unique
  status          OrderStatus @default(PENDING)
  items           OrderItem[]
  messages        OrderMessage[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User?       @relation(fields: [userId], references: [id])
}

model OrderMessage {
  id        String     @id @default(cuid())
  orderId   String
  sender    ChatSender
  text      String
  createdAt DateTime   @default(now())
  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  menuItemId String
  name       String
  quantity   Int
  priceCents Int
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
