generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CateringRequest {
  id            String            @id @default(cuid())
  name          String
  phone         String
  email         String
  eventDate     String?
  guests        String?
  location      String?
  notes         String?
  internalNotes String?
  status        String            @default("NEW")
  isArchived    Boolean           @default(false)
  chatToken     String            @unique @default(cuid())
  chatEnabled   Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now()) @updatedAt
  selections    Json?
  messages      CateringMessage[]
}

model CateringMessage {
  id        String          @id @default(cuid())
  requestId String
  sender    ChatSender
  text      String
  createdAt DateTime        @default(now())
  request   CateringRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  imageUrl    String?
  category    String
  isVeg       Boolean  @default(false)
  isSpicy     Boolean  @default(false)
  isPopular   Boolean  @default(false)
  isAvailable Boolean  @default(true)
  inPos       Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isAvailable, sortOrder])
}

model MenuCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id              String   @id @default("global")
  phone           String   @default("")
  instagramUrl    String   @default("")
  truckToday      String   @default("")
  truckNext       String   @default("")
  updatedAt       DateTime @updatedAt
  nextDate        String   @default("")
  nextEnd         String   @default("")
  nextLocation    String   @default("")
  nextNotes       String   @default("")
  nextStart       String   @default("")
  todayEnd        String   @default("")
  todayLocation   String   @default("")
  todayNotes      String   @default("")
  todayStart      String   @default("")
  todayStatus     String   @default("CLOSED")
  bannerEnabled   Boolean  @default(false)
  bannerText      String?  @default("")
  businessName    String?  @default("Indian Food Truck")
  cityState       String?  @default("Hartford, CT")
  footerMessage   String?  @default("")
  publicEmail     String?  @default("")
  logoUrl         String?  @default("")
  cateringEnabled Boolean  @default(true)
}

model SavedLocation {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  createdAt DateTime @default(now())
}

model CateringItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  priceKind   String
  amount      Float?
  minPeople   Int?
  unit        String?
  halfPrice   Float?
  fullPrice   Float?
  isVeg       Boolean  @default(false)
  isSpicy     Boolean  @default(false)
  isPopular   Boolean  @default(false)
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isAvailable, sortOrder])
}

model CateringCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  subtitle  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

enum ChatSender {
  CUSTOMER
  ADMIN
}
