generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CateringRequest {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  eventDate String?
  guests    String?
  location  String?
  notes         String?
  internalNotes String?
  status        String   @default("NEW") // NEW, CONTACTED, DONE
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  imageUrl    String?
  category    String // Starters, Mains, Wraps, Drinks, Dessert
  isVeg       Boolean  @default(false)
  isSpicy     Boolean  @default(false)
  isPopular   Boolean  @default(false)
  isAvailable Boolean  @default(true)
  inPos       Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isAvailable, sortOrder])
}

model MenuCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id           String   @id @default("global")
  phone        String   @default("")
  instagramUrl String   @default("")
  truckToday   String   @default("")
  truckNext    String   @default("")
  updatedAt    DateTime @updatedAt
}
