generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CateringRequest {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  eventDate String?
  guests    String?
  location  String?
  notes     String?
  status    String   @default("NEW") // NEW, CONTACTED, DONE
  createdAt DateTime @default(now())
}
