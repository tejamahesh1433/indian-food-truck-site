generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CateringRequest {
  id            String            @id @default(cuid())
  name          String
  phone         String
  email         String
  eventDate     String?
  guests        String?
  location      String?
  notes         String?
  internalNotes String?
  status        String            @default("NEW")
  isArchived    Boolean           @default(false)
  chatToken     String            @unique @default(cuid())
  chatEnabled   Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now()) @updatedAt
  selections    Json?
  messages      CateringMessage[]
}

model CateringMessage {
  id        String          @id @default(cuid())
  requestId String
  sender    ChatSender
  text      String
  createdAt DateTime        @default(now())
  request   CateringRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

model MenuItem {
  id             String         @id @default(cuid())
  name           String
  description    String?
  priceCents     Int
  imageUrl       String?
  category       String
  isVeg          Boolean        @default(false)
  isNonVeg       Boolean        @default(false)
  isSpicy        Boolean        @default(false)
  isPopular      Boolean        @default(false)
  isAvailable    Boolean        @default(true)
  inPos          Boolean        @default(true)
  sortOrder      Int            @default(0)
  allergens      String[]       @default([])
  stockCount     Int?
  isStockTracked Boolean        @default(false)
  prepTime       String?        @default("15-20")
  pairedItemIds  String[]       @default([])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  sendToKds      Boolean        @default(true)
  reviews        Review[]
  addons         MenuAddon[]
  favoritedBy    UserFavorite[]
  orderItems     OrderItem[]

  @@index([category, isAvailable, sortOrder])
}

model MenuAddon {
  id          String   @id @default(cuid())
  menuItemId  String
  name        String
  priceCents  Int      @default(0)
  isAvailable Boolean  @default(true)
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

model MenuCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id              String   @id @default("global")
  phone           String   @default("")
  instagramUrl    String   @default("")
  truckToday      String   @default("")
  truckNext       String   @default("")
  updatedAt       DateTime @updatedAt
  nextDate        String   @default("")
  nextEnd         String   @default("")
  nextLocation    String   @default("")
  nextNotes       String   @default("")
  nextStart       String   @default("")
  todayEnd        String   @default("")
  todayLocation   String   @default("")
  todayNotes      String   @default("")
  todayStart      String   @default("")
  todayStatus     String   @default("CLOSED")
  bannerEnabled   Boolean  @default(false)
  bannerText      String?  @default("")
  businessName    String?  @default("Indian Food Truck")
  cityState       String?  @default("Hartford, CT")
  footerMessage   String?  @default("")
  publicEmail     String?  @default("")
  logoUrl         String?  @default("")
  cateringEnabled Boolean  @default(true)
  weeklySchedule  Json?
  adminAccessPin  String?  @default("")

  // Email feature toggles (for free Resend limits)
  emailOrderStatusUpdates Boolean @default(true)
  emailNewsletterSend     Boolean @default(true)
  emailVerificationRequired Boolean @default(false)
  emailAdminAlerts        Boolean @default(true)
}

model SavedLocation {
  id        String   @id @default(cuid())
  userId    String
  name      String
  address   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model CateringItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  priceKind   String
  amount      Float?
  minPeople   Int?
  unit        String?
  halfPrice   Float?
  fullPrice   Float?
  isVeg       Boolean  @default(false)
  isSpicy     Boolean  @default(false)
  isPopular   Boolean  @default(false)
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isAvailable, sortOrder])
}

model CateringCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  subtitle  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  password      String?
  accounts      Account[]
  orders        Order[]
  sessions      Session[]
  reviews       Review[]
  favorites     UserFavorite[]
  savedLocations SavedLocation[]
  emailNotifications Boolean     @default(true)
  marketingEmails    Boolean     @default(false)
}

model UserFavorite {
  id         String   @id @default(cuid())
  userId     String
  menuItemId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([userId, menuItemId])
  @@index([userId])
  @@index([menuItemId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model Order {
  id                  String         @id @default(cuid())
  customerName        String
  customerEmail       String
  customerPhone       String
  totalAmount         Int
  stripeSessionId     String?        @unique
  stripePaymentIntentId String?
  stripeChargeId      String?
  posOrderId          String?        // POS system order ID (Square, Toast, etc)
  status              OrderStatus    @default(PENDING)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  userId              String?
  chatToken           String?
  notes               String?
  serviceFeeAmount    Int            @default(0)
  subtotalAmount      Int            @default(0)
  taxAmount           Int            @default(0)
  user                User?          @relation(fields: [userId], references: [id])
  items               OrderItem[]
  messages            OrderMessage[]
  reviews             Review[]
}

model OrderMessage {
  id        String     @id @default(cuid())
  orderId   String
  sender    ChatSender
  text      String
  createdAt DateTime   @default(now())
  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  menuItemId String
  name       String
  quantity   Int
  priceCents Int
  notes      String?
  addons     Json?
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model Review {
  id         String   @id @default(cuid())
  orderId    String?
  menuItemId String?
  userId     String?
  name       String
  rating     Int
  text       String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Relations
  order    Order?    @relation(fields: [orderId], references: [id])
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
  @@index([userId])
}

model AdminLoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  count     Int      @default(1)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ip, expiresAt])
}

enum ChatSender {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

model TodaysSpecial {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  imageUrl    String?
  isActive    Boolean  @default(true)
  isVeg       Boolean  @default(false)
  isNonVeg    Boolean  @default(false)
  isSpicy     Boolean  @default(false)
  isPopular   Boolean  @default(false)
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model SupportChat {
  id        String           @id @default(cuid())
  email     String           @unique
  name      String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  SupportMessage[]
}

model SupportMessage {
  id        String      @id @default(cuid())
  chatId    String
  sender    ChatSender
  text      String
  createdAt DateTime    @default(now())
  chat      SupportChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}
