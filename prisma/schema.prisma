generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CateringRequest {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  eventDate String?
  guests    String?
  location  String?
  notes     String?
  status    String   @default("NEW") // NEW, CONTACTED, DONE
  createdAt DateTime @default(now())
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  imageUrl    String?
  category    String   // Starters, Mains, Wraps, Drinks, Dessert
  tags        String[] // ["Veg", "Spicy", "Popular"]
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
