generator client {
  provider = "prisma-client-js"
}

enum ChatSender {
  CUSTOMER
  ADMIN
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CateringRequest {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  eventDate String?
  guests    String?
  location  String?
  notes         String?
  internalNotes String?
  status        String   @default("NEW") // NEW, CONTACTED, DONE
  isArchived    Boolean        @default(false)

  // Chat capability
  chatToken     String        @unique @default(cuid())
  chatEnabled   Boolean       @default(true)
  messages      CateringMessage[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model CateringMessage {
  id        String     @id @default(cuid())
  requestId String
  request   CateringRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  sender    ChatSender
  text      String
  createdAt DateTime   @default(now())

  @@index([requestId, createdAt])
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  imageUrl    String?
  category    String // Starters, Mains, Wraps, Drinks, Dessert
  isVeg       Boolean  @default(false)
  isSpicy     Boolean  @default(false)
  isPopular   Boolean  @default(false)
  isAvailable Boolean  @default(true)
  inPos       Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isAvailable, sortOrder])
}

model MenuCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id           String   @id @default("global")
  phone        String   @default("")
  instagramUrl String   @default("")
  publicEmail   String? @default("")
  businessName  String? @default("Indian Food Truck")
  cityState     String? @default("Hartford, CT")
  footerMessage String? @default("")
  bannerEnabled Boolean @default(false)
  bannerText    String? @default("")

  // Advanced Schedule Today
  todayLocation String @default("")
  todayStart    String @default("")
  todayEnd      String @default("")
  todayStatus   String @default("CLOSED") // SERVING, ON_THE_WAY, CLOSED
  todayNotes    String @default("")

  // Advanced Schedule Next
  nextLocation String @default("")
  nextDate     String @default("")
  nextStart    String @default("")
  nextEnd      String @default("")
  nextNotes    String @default("")

  // Legacy fields (keeping for migration)
  truckToday String @default("")
  truckNext  String @default("")

  updatedAt DateTime @updatedAt
}

model SavedLocation {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  createdAt DateTime @default(now())
}
